rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Allow updating only counter fields (likeCount, commentCount, viewCount)
    function isCounterOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['likeCount', 'commentCount', 'viewCount']);
    }

    // isPinned 필드는 Firebase console / Admin SDK 전용.
    // 일반 클라이언트가 isPinned를 변경하지 못하도록 막음.
    function isPinnedUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isPinned']);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if false;

      // --- Saved Posts ---
      // Users manage their own saved posts.
      // Document ID = postId.
      match /savedPosts/{postId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.postId == postId
          && request.resource.data.keys().hasOnly(['postId', 'savedAt', 'postSnapshot']);
      }

      // --- Recently Viewed ---
      // Users manage their own recently viewed posts.
      // Document ID = postId.
      match /recentlyViewed/{postId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.postId == postId
          && request.resource.data.keys().hasOnly(['postId', 'viewedAt', 'postSnapshot']);
      }
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      // 작성자는 isPinned 제외 모든 필드 수정 가능; 누구든 카운터 필드만 수정 가능
      allow update: if isSignedIn() && (
        (resource.data.authorId == request.auth.uid && isPinnedUnchanged()) ||
        isCounterOnlyUpdate()
      );
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
      }

      // Likes subcollection: one document per user, keyed by userId
      match /likes/{userId} {
        allow read: if isSignedIn();
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    // --- Reports ---
    // Any signed-in user can file a report; only the reporter can read their own.
    // Updates/deletes are admin-only (via Firebase console / Admin SDK).
    match /reports/{reportId} {
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow read: if isSignedIn() && resource.data.reporterId == request.auth.uid;
      allow update, delete: if false;
    }

    // --- Blocks ---
    // Users manage their own blocks. Document ID = "{blockerId}_{blockedId}".
    match /blocks/{blockId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.blockerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.blockerId == request.auth.uid;
      allow update: if false;
    }

    // --- Push Tokens ---
    // Any signed-in user can read tokens (needed to send push to others).
    // Only the token owner can write their own token.
    match /pushTokens/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // --- Notifications ---
    // Users read/update (mark read) their own notifications.
    // Any signed-in user can create notifications for others (client-side triggers).
    // Migrate to Cloud Functions writes only once scale requires it.
    match /notifications/{userId}/items/{notifId} {
      allow read, update: if isOwner(userId);
      allow create: if isSignedIn();
      allow delete: if isOwner(userId);
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && (
        resource == null ||
        request.auth.uid in resource.data.participantIds
      );
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participantIds;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
        allow create: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }
  }
}
