rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Profile images: public read, owner write
    match /profile-images/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Post images: public read, signed-in user write (owner of the post folder)
    match /post-images/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
